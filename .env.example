# Sao chép: cp .env.example .env
#
# Thứ tự: `make d-up` (MySQL + gateway + mạng base_shared_net) trước khi bật api/portal.
#
# Gateway: cp routes.json.example routes.json — xem ROUTES.md
#   make gen-sites   hoặc   bash gen-gateway-sites.sh
# Cert + sites: make gen-ssl   hoặc   bash gen-dev-ssl.sh .env certs
#
# Windows bundle: C:\Users\Public\dev_ssl\<PROJECT_NAME>\
# Tiền tố container/volume Docker (vd. local_dev_mysql, local_dev_gateway_nginx)
PROJECT_NAME=demo_unittest

# TLS — host routes.json: *.<SSL_DOMAIN_BASE> (vd. saas-api.local.com)
SSL_DOMAIN_BASE=local.com

# --- print-hosts-from-env.sh ---
HOSTS_IP=127.0.0.1

# --- MySQL (docker-compose + initdb; khớp api/src/.env) ---
MYSQL_ROOT_PASSWORD=123456
MYSQL_DB_LOCAL=db_local
MYSQL_DB_TEST=laravel_test
MYSQL_APP_USER=smart
MYSQL_APP_PASSWORD=smart

BASE_SHARED_NETWORK_NAME=base_shared_net
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MYSQL_PORT=3306
# MySQL data — bind mount ra folder host (mặc định ./data/mysql, ./data/mysql-80)
# MYSQL_DATA_DIR=./data/mysql
# MYSQL_80_DATA_DIR=./data/mysql-80
# MySQL 8.0 (mysql_native_password), expose host port
MYSQL_80_PORT=13307

# --- PostgreSQL (docker-compose; alias mạng saas-postgres) ---
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=one_crm
POSTGRES_PORT=15432
# POSTGRES_DATA_DIR=./data/postgres

# pgAdmin — https://pgadmin.local.com
PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin

# Redis Commander — https://redisadmin.local.com (label:host:port)
REDIS_PORT=6379
REDIS_COMMANDER_HOSTS=local:redis:6379
# REDIS_DATA_DIR=./data/redis

# phpMyAdmin import lớn (gateway timeout + PHP + MySQL)
PMA_UPLOAD_LIMIT=512M
PMA_MEMORY_LIMIT=512M
PMA_MAX_EXECUTION_TIME=3600

# Gateway → API: proxy tới <stack>-api-nginx:80 (stack = api.stack trong routes.json, khớp API_STACK_PREFIX).
# Gateway → portal: <stack>-portal-node:3000 trên base_shared_net (pnpm dev chỉ trong container).
# Gateway → mairy external (fullsco/admin/scenario): container = dev_external_nginx:808x trên base_shared_net
EXTERNAL_GATEWAY_PROXY=container

# docker-compose.external.yml — cổng publish (khớp docker/routes.txt dòng external 3 site)
HOST_UID=1000
HOST_GID=1000
EXTERNAL_PHP82_PORT=18081
EXTERNAL_PHP82_SCENARIO_PORT=18084
EXTERNAL_PHP83_PORT=18082
EXTERNAL_NODE_PORT=3001
EXTERNAL_SELENIUM_PORT=4444
EXTERNAL_SELENIUM_VNC_PORT=5900

# mairy-crawl (external-crawler) — override tùy chọn; mặc định trong compose
# CRAWLER_SQS_TASK_URL=http://localstack:4566/000000000000/queue_crawl_task.fifo

# --- docker-compose.services.yml (LocalStack + StackPort + …) ---
AWS_REGION=us-east-1
